# Northstar — environment example
# Copy to .env.local for local development. All values are optional.
# The app runs fine without any env vars — it defaults to mock AI mode.

# ------------------------------------------------------------
# Client-visible (safe to ship to the browser)
# ------------------------------------------------------------

# Which AI provider the client expects. Leave empty or "mock" for browser-local mock mode.
# Set to "server" when you have deployed an /api/ai route on a server-capable host.
VITE_AI_PROVIDER=mock

# The path of the server AI endpoint. Only used when VITE_AI_PROVIDER=server.
# VITE_AI_ENDPOINT=/api/ai

# ------------------------------------------------------------
# Server-only (DO NOT ship to the browser)
# These must be set on your server host (Vercel, Cloudflare, Fly, etc.),
# not in a VITE_ variable. They are listed here purely for documentation.
# ------------------------------------------------------------

# AI_PROVIDER=gemini
# AI_API_KEY=sk-...
# AI_MODEL=gemini-2.5-pro
